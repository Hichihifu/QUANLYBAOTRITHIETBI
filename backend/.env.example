# --- CẤU HÌNH KẾT NỐI SQL SERVER ---
# Tài khoản đăng nhập SQL Server (Mặc định thường là sa)
DB_USER=your_username_here

# Mật khẩu tài khoản SQL Server
DB_PASSWORD=your_password_here

# Địa chỉ server (Nếu chạy máy cục bộ thì để localhost)
DB_SERVER=localhost

# Tên Cơ sở dữ liệu đã tạo từ file Init_DB.sql
DB_NAME=QuanLyBaoTri


# --- CẤU HÌNH GOOGLE GEMINI AI ---
# Lấy mã khóa tại: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here


# --- CẤU HÌNH SERVER BACKEND ---
# Cổng chạy ứng dụng Node.js
PORT=3000